// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  username  String  @unique
  password  String
  role      String  @default("user") // admin or user
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  inventories Inventory[]
  
  @@map("users")
}

model Inventory {
  id            Int     @id @default(autoincrement())
  userId        Int
  userName      String
  deviceType    String  // Laptop, PC, MacBook, Mac Mini, Mobile/Tablet, Network Device, Other
  deviceMake    String
  deviceModel   String
  serialNumber  String  @unique
  operatingSystem String
  processor     String
  ram           String  // e.g., "8GB", "16GB"
  disk          String  // e.g., "256GB SSD"
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("inventory")
  @@index([userId])
  @@index([deviceType])
  @@index([serialNumber])
}

model ImportLog {
  id            Int     @id @default(autoincrement())
  fileName      String
  totalRecords  Int
  successCount  Int
  failureCount  Int
  duplicates    Int
  errorDetails  String?
  createdAt     DateTime @default(now())
  
  @@map("import_logs")
}
